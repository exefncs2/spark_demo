    "\n",
    "try:\n",
    "    connection = pika.BlockingConnection(pika.ConnectionParameters('localhost'))\n",
    "    print(\"RabbitMQ 連接成功！\")\n",
    "    connection.close()\n",
    "except Exception as e:\n",
    "    print(f\"RabbitMQ 連接失敗: {e}\")"
   ]
